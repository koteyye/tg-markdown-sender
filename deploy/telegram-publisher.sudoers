deploy ALL=(root) NOPASSWD: @SYSTEMCTL@ restart telegram-publisher.service
deploy ALL=(root) NOPASSWD: @SYSTEMCTL@ is-active --quiet telegram-publisher.service
deploy ALL=(root) NOPASSWD: @SYSTEMCTL@ status telegram-publisher.service --no-pager
deploy ALL=(root) NOPASSWD: @JOURNALCTL@ -u telegram-publisher.service -n 100 --no-pager
